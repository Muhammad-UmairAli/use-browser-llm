{
  "name": "use-local-llm",
  "version": "0.1.0",
  "description": "Headless React hook for running LLMs locally in the browser via WebGPU, with zero backend and complete privacy.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muhammad-UmairAli/use-local-llm.git"
  },
  "homepage": "https://github.com/Muhammad-UmairAli/use-local-llm#readme",
  "bugs": {
    "url": "https://github.com/Muhammad-UmairAli/use-local-llm/issues"
  },
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.browser.config.ts"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.79",
    "comlink": "^4.4.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.7",
    "@vitest/browser": "2.1.9",
    "@webgpu/types": "^0.1.71",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
