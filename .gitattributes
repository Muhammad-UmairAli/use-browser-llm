# Line ending normalization. All text files use LF in the repository;
# Git checks them out with LF on every platform (Windows, macOS, Linux).

* text=auto eol=lf

# Explicit text — force LF
*.sh       text eol=lf
*.bash     text eol=lf
*.py       text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.jsonc    text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.toml     text eol=lf
*.txt      text eol=lf
*.bicep    text eol=lf
*.tf       text eol=lf
*.sql      text eol=lf
*.env      text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Binary — never modify
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.7z       binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.otf      binary
*.mp4      binary
*.webm     binary
*.mov      binary

# SVG is XML — safe as text
*.svg      text eol=lf

# Lock files — text but suppress diff (noisy)
package-lock.json  -diff
poetry.lock        -diff
yarn.lock          -diff
Pipfile.lock       -diff
