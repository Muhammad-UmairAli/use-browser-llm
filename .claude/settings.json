{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh repo view:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm install:*)",
      "Bash(python tools/log-agent.py:*)",
      "Bash(python3 tools/log-agent.py:*)",
      "Bash(py tools/log-agent.py:*)",
      "Bash(python tools/log-time.py:*)",
      "Bash(python3 tools/log-time.py:*)",
      "Bash(py tools/log-time.py:*)",
      "Bash(python tools/start-task.py:*)",
      "Bash(python3 tools/start-task.py:*)",
      "Bash(py tools/start-task.py:*)",
      "Bash(python tools/estimate.py:*)",
      "Bash(python3 tools/estimate.py:*)",
      "Bash(py tools/estimate.py:*)",
      "Bash(python tools/open-phase.py:*)",
      "Bash(python3 tools/open-phase.py:*)",
      "Bash(py tools/open-phase.py:*)",
      "Bash(python tools/close-phase.py:*)",
      "Bash(python3 tools/close-phase.py:*)",
      "Bash(py tools/close-phase.py:*)",
      "Bash(python tools/render-check.py:*)",
      "Bash(python3 tools/render-check.py:*)",
      "Bash(py tools/render-check.py:*)",
      "Bash(python tools/kit-doctor.py:*)",
      "Bash(python3 tools/kit-doctor.py:*)",
      "Bash(py tools/kit-doctor.py:*)",
      "Bash(python tools/export-phase-times.py:*)",
      "Bash(python3 tools/export-phase-times.py:*)",
      "Bash(py tools/export-phase-times.py:*)",
      "Bash(./tools/render-check.sh:*)",
      "Bash(bash tools/render-check.sh:*)",
      "Bash(./tools/whats-next.sh:*)",
      "Bash(bash tools/whats-next.sh:*)"
    ],
    "ask": [
      "Bash(gh pr merge:*)",
      "Bash(gh api:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(rm:*)",
      "Bash(az deployment:*)",
      "Bash(az containerapp update:*)",
      "Bash(az containerapp delete:*)",
      "Bash(az postgres:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin master:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-commit-to-main.sh"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-closes-on-pr.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-agent-on-spawn.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-skill-on-invoke.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/warn-on-stale-time-log.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-agent-on-complete.sh"
          }
        ]
      }
    ]
  }
}
