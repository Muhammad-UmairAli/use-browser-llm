root = true

[*]
end_of_line = lf
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.{md,markdown}]
# Markdown trailing spaces are line breaks; don't strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bash}]
end_of_line = lf
